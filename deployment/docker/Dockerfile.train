# MinIVess MLOps v2 — Model Training Flow (Flow 2)
# CUDA-enabled: PyTorch, MONAI, Optuna, full ML stack.
#
# Build: docker build -t minivess-train:latest -f deployment/docker/Dockerfile.train .
# Requires: NVIDIA Container Toolkit for GPU access

FROM nvidia/cuda:12.6.3-runtime-ubuntu24.04 AS train-base

LABEL flow="train"
LABEL description="Model training flow — CUDA, PyTorch, MONAI, Optuna"

# System dependencies (Ubuntu 24.04 ships Python 3.12 natively)
# CUDA 12.6 runtime is backward-compatible; PyTorch bundles its own CUDA libs.
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-venv \
    python3-pip \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Create non-root user
RUN useradd --create-home --shell /bin/bash minivess
USER minivess
WORKDIR /app

# Copy project metadata
COPY --chown=minivess:minivess pyproject.toml uv.lock* ./

# Install full ML dependencies
RUN uv sync --no-dev --no-install-project 2>/dev/null || true

# Copy source code and scripts
COPY --chown=minivess:minivess src/ src/
COPY --chown=minivess:minivess configs/ configs/
COPY --chown=minivess:minivess scripts/ scripts/

ENV PYTHONPATH=/app/src
ENV PYTHONUNBUFFERED=1

# Docker context marker — detected by _require_docker_context() in train_flow.py
ENV DOCKER_CONTAINER=1

# Volume-mapped paths — must match docker-compose.flows.yml volume declarations.
# Override at runtime via environment section if container mounts differ.
ENV DATA_DIR=/app/data
ENV MLFLOW_TRACKING_URI=file:///app/mlruns
ENV CHECKPOINT_DIR=/app/checkpoints
ENV LOGS_DIR=/app/logs
ENV SPLITS_DIR=/app/configs/splits

# HuggingFace token for gated models (SAM3). Pass at runtime:
#   docker compose run -e HF_TOKEN=$HF_TOKEN train
# or set in docker-compose.flows.yml environment section.

CMD ["python", "-m", "minivess.orchestration.flows.train_flow"]
