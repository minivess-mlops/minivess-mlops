# MinIVess MLOps v2 — QA Flow (Flow 6)
# MLflow validation, param checks, ghost run cleanup.
#
# Build: docker build -t minivess-qa:latest -f deployment/docker/Dockerfile.qa .

FROM minivess-base:latest

LABEL flow="qa"
LABEL description="QA flow — MLflow validation, param checks, ghost cleanup"

# Copy scripts
COPY --chown=minivess:minivess scripts/ scripts/

CMD ["python", "-m", "minivess.orchestration.flows.qa_flow"]
