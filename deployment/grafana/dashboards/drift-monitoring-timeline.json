            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "title": "Champion Model Dice Score",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "minivess_champion_dice",
          "legendFormat": "Champion Dice"
        }
      ],
      "fieldConfig": {
        "defaults": {
