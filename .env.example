# MinIVess MLOps — Environment Variables
#
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored — never commit real tokens.
# In Docker/RunPod: set these as container environment variables instead.

# ─── HuggingFace (required for gated models: SAM3, VesselFM) ──────────────────
# Get your token from: https://huggingface.co/settings/tokens
# Request SAM3 access: https://huggingface.co/facebook/sam3
HF_TOKEN=hf_REPLACE_WITH_YOUR_TOKEN

# ─── MLflow ────────────────────────────────────────────────────────────────────
# Default: local filesystem backend in ./mlruns (no server needed for dev)
MLFLOW_TRACKING_URI=mlruns
# Uncomment for remote MLflow server:
# MLFLOW_TRACKING_URI=http://localhost:5000

# ─── Infrastructure (used by docker-compose) ──────────────────────────────────
POSTGRES_USER=minivess
POSTGRES_PASSWORD=minivess_secret
POSTGRES_DB=mlflow
POSTGRES_PORT=5432

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret

# ─── Prefect ──────────────────────────────────────────────────────────────────
PREFECT_API_URL=http://localhost:4200/api

# ─── Langfuse (optional, self-hosted LLM observability) ──────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
