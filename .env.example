# MinIVess MLOps — Environment Variables
#
# Team Setup (multi-developer with SOPS+age encryption):
#   Install age:  sudo apt-get install age
#   Install sops: https://github.com/getsops/sops/releases
#   Decrypt env:  bash scripts/setup_dev.sh
#   Rotate creds: uv run python scripts/_rotate_credentials.py
#
# SINGLE SOURCE OF TRUTH for all configurable values.
# Every port, hostname, credential, and path in this project is defined HERE.
# Nowhere else. Docker Compose, Python code, and deployment YAML files all
# reference these values — they never define their own.
#
# Setup:
#   cp .env.example .env
#   # Edit .env with your actual values
#
# Rules (CLAUDE.md Rule #22):
#   - If a value is not in .env.example, it does not exist as config.
#   - Never hardcode a URL, port, or credential in a Dockerfile, compose file,
#     Python constant, or TOML file. Always reference ${VAR_NAME} from here.
#   - Docker Compose uses ${VAR:-fallback} where fallback == the default below.
#   - .env is gitignored — never commit real secrets.

# ─── HuggingFace (required for gated models: SAM3, VesselFM) ──────────────────
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=hf_REPLACE_WITH_YOUR_TOKEN

# ─── MLflow ────────────────────────────────────────────────────────────────────
# SINGLE tracking URI for ALL environments. Override mechanism:
#   - Local dev (host):    http://localhost:5000 (default below — MLflow via docker-compose)
#   - Docker Compose:      http://minivess-mlflow:5000 (hardcoded in docker-compose.flows.yml)
#   - DagsHub (primary):   https://dagshub.com/petteriTeikari/vascadia.mlflow
#   - SkyPilot RunPod:     Points to DagsHub MLflow (same URI as above)
# Use "mlruns" for local dev without the infra stack.
MLFLOW_TRACKING_URI=https://dagshub.com/petteriTeikari/vascadia.mlflow

# Port (host-side mapping AND docker-internal)
MLFLOW_PORT=5000

# Artifact bucket (MinIO/S3)
MLFLOW_ARTIFACT_BUCKET=mlflow-artifacts

# MLflow basic-auth credentials
# For DagsHub: USERNAME=your_dagshub_username, PASSWORD=your_dagshub_token
# For self-hosted: set per deployment/mlflow/auth.ini.example
MLFLOW_TRACKING_USERNAME=petteriTeikari
MLFLOW_TRACKING_PASSWORD=

# ─── DagsHub (experiment tracking + DVC storage) ─────────────────────────────
# Free tier: 20 GB storage, unlimited public experiments, hosted MLflow.
# Token from: https://dagshub.com/user/settings/tokens
# Used for: MLflow auth (as MLFLOW_TRACKING_PASSWORD), DVC remote auth.
# The DAGSHUB_TOKEN serves as BOTH the MLflow password AND the DVC access key.
DAGSHUB_TOKEN=

# ─── MinIO (S3-compatible artifact store) ─────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# Docker-internal service name — must match container_name in docker-compose.yml
MINIO_DOCKER_HOST=minio

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=minivess
POSTGRES_PASSWORD=minivess_secret
POSTGRES_PORT=5432
# Docker-internal service name
POSTGRES_DOCKER_HOST=postgres
# Per-service database names (all on the same PostgreSQL instance)
POSTGRES_DB_MLFLOW=mlflow
POSTGRES_DB_PREFECT=prefect
POSTGRES_DB_LANGFUSE=langfuse

# ─── Prefect ───────────────────────────────────────────────────────────────────
# HOST-side URL (used by CLI commands and Python on host)
PREFECT_API_URL=http://localhost:4200/api
PREFECT_PORT=4200
# Docker-internal service name — must match container_name in docker-compose.yml
PREFECT_DOCKER_HOST=minivess-prefect

# ─── Langfuse (self-hosted LLM observability) ─────────────────────────────────
LANGFUSE_PORT=3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001
# Server-side secrets — generate with: openssl rand -hex 32
LANGFUSE_SECRET=changeme-langfuse-secret
LANGFUSE_SALT=changeme-langfuse-salt

# ─── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ─── Dashboard (React UI + FastAPI API) ───────────────────────────────────────
# Port 3000=Grafana, 3001=Langfuse — dashboard UI uses 3002.
DASHBOARD_UI_PORT=3002
DASHBOARD_API_PORT=8090
DASHBOARD_REFRESH_INTERVAL_S=30
DASHBOARD_HEALTH_CHECK_INTERVAL_S=300

# ─── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090

# ─── Alertmanager (drift alert dispatch) ──────────────────────────────────────
ALERTMANAGER_PORT=9093
ALERTMANAGER_WEBHOOK_URL=http://host.docker.internal:9094/webhook

# ─── Evidently (drift monitoring service) ─────────────────────────────────────
EVIDENTLY_PORT=8085

# ─── Sentry (OPTIONAL — error tracking) ───────────────────────────────────────
# Sentry captures unhandled exceptions and performance traces.
# Empty = disabled (default). Set to your Sentry project DSN to enable.
# Get your DSN: https://docs.sentry.io/product/sentry-basics/concepts/dsn-key/
SENTRY_DSN=

# ─── PostHog (OPTIONAL — product analytics) ──────────────────────────────────
# PostHog captures usage analytics (flow runs, model choices, etc.).
# Empty = disabled (default). Set to your PostHog project API key to enable.
# Get your key: https://posthog.com/docs/getting-started/send-events
POSTHOG_KEY=
POSTHOG_HOST=https://app.posthog.com

# ─── OpenTelemetry Collector ───────────────────────────────────────────────────
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318

# ─── BentoML ───────────────────────────────────────────────────────────────────
BENTOML_PORT=3333
BENTOML_HOME=/home/minivess/bentoml
BENTOML_IMAGE=bentoml/bento-server:latest
BENTOML_DOCKER_HOST=minivess-bento

# ─── Host-side paths (machine-specific — REQUIRED, no default) ────────────────
# MODEL_CACHE_HOST_PATH: local directory that persists HuggingFace + PyTorch weights.
# Avoids re-downloading SAM3 (~9 GB), MONAI bundles, etc. on every container restart.
# REQUIRED: set to your local download cache directory. No default — machine-specific.
# Example: MODEL_CACHE_HOST_PATH=/home/youruser/download_cache
MODEL_CACHE_HOST_PATH=/replace/with/your/local/model/cache/path

# ─── Container-internal artifact paths ─────────────────────────────────────────
# These are injected by docker-compose into ALL flow containers.
# DO NOT hardcode in Dockerfiles — Dockerfiles set structural paths only.
# CLAUDE.md Rule #22: all service paths defined here, referenced as ${VAR:-default}.
DATA_DIR=/app/data
CHECKPOINT_DIR=/app/checkpoints
LOGS_DIR=/app/logs
SPLITS_DIR=/app/configs/splits

# ─── Data Quality Gate (pytest-only escape hatch) ────────────────────────────
# Skips ALL data quality gates when set to 1. For pytest only — never in production.
# MINIVESS_SKIP_QUALITY_GATE=1

# ─── CUDA Toolkit ─────────────────────────────────────────────────────────────
# CUDA 12.6 toolkit is at /usr/local/cuda-12.6. The Ubuntu nvidia-cuda-toolkit
# package (11.5) installs /usr/bin/nvcc which shadows the newer version.
# CUDA_HOME ensures mamba-ssm and causal-conv1d compile with the right nvcc.
CUDA_HOME=/usr/local/cuda-12.6

# ─── PyTorch CUDA Memory ───────────────────────────────────────────────────────
# expandable_segments:True reduces fragmentation, recovering 200-400MB on 8GB GPUs.
# Fixes sam3_hybrid OOM: 7.15GB in use + 82MB alloc request → fragmented = OOM.
# Set to empty string to disable (for debugging memory issues).
# NOTE: PyTorch 2.x uses PYTORCH_ALLOC_CONF (not PYTORCH_CUDA_ALLOC_CONF).
PYTORCH_ALLOC_CONF=expandable_segments:True

# ─── HPO (Hyperparameter Optimization) ─────────────────────────────────────────
# PostgreSQL is the ONLY Optuna backend in this project. SQLite and in-memory
# are banned (CLAUDE.md MEMORY: PostgreSQL is ONLY Database 2026-03-08).
POSTGRES_DB_OPTUNA=optuna
OPTUNA_STORAGE_URL=postgresql+psycopg2://minivess:minivess_secret@postgres:5432/optuna
# Replica index for parallel HPO workers (overridden by docker compose --scale)
REPLICA_INDEX=0

# ─── Prefect logging ────────────────────────────────────────────────────────────
# Comma-separated list of logger names forwarded to Prefect UI
PREFECT_LOGGING_EXTRA_LOGGERS=minivess


# ─── Additional Services ───────────────────────────────────────────────────────
LABEL_STUDIO_PORT=8080
MONAI_LABEL_PORT=8000
OLLAMA_PORT=11434
MARQUEZ_PORT=5001
MARQUEZ_API_PORT=5002
# Marquez API URL for OpenLineage emission (Issue #799).
# Set to enable HTTP transport to Marquez. Leave empty for local-only mode.
# Docker Compose: http://minivess-marquez:5000 (container-internal)
# Host-side: http://localhost:${MARQUEZ_API_PORT:-5002}
MARQUEZ_URL=

# ─── CopilotKit (agentic dashboard UI backend) ──────────────────────────────
# CopilotKit runtime serves as the AG-UI protocol bridge between the React
# dashboard frontend and Pydantic AI agents. Self-hosted via Docker.
COPILOTKIT_PORT=4111

# =============================================================================
#  CLOUD / REMOTE TRAINING (OPTIONAL)
# =============================================================================
# Everything below is OPTIONAL. You only need these if you want to:
#   - Train on cloud GPUs via SkyPilot (RunPod, Lambda, AWS, GCP)
#   - Host MLflow on Oracle Cloud for sharing experiments publicly
#   - Manage cloud infrastructure via Pulumi IaC
#   - Use a custom domain (e.g., mlflow.minivess.fi) via Cloudflare DNS
#
# If you only train locally on your own GPU, SKIP THIS ENTIRE SECTION.
# The local Docker Compose stack works without any of these.
#
# Setup tutorial: docs/planning/cloud-tutorial.md

# ─── Remote MLflow Server (OPTIONAL — for SkyPilot + shared experiments) ─────
# When training on cloud GPUs, SkyPilot VMs cannot reach your local Docker
# MLflow at http://minivess-mlflow:5000. A remote MLflow server solves this.
#
# WHO NEEDS THIS: Anyone using SkyPilot for cloud GPU training, OR anyone who
# wants to share MLflow experiment results publicly (e.g., paper reviewers).
#
# WHO CAN SKIP: Anyone training only on their local GPU.
#
# To use a remote MLflow server, set MLFLOW_TRACKING_URI (in MLflow section above)
# to the remote URL (e.g., https://mlflow-xxxx-ey.a.run.app for GCP Cloud Run).
# Set MLFLOW_TRACKING_USERNAME/PASSWORD for authenticated servers.

# ─── SkyPilot Compute Offloading (OPTIONAL — cloud GPU training) ─────────────
# SkyPilot provisions cloud GPUs (RunPod, Lambda, AWS, GCP) and runs training
# jobs on them. It handles multi-cloud failover, spot instances, and auto-shutdown.
#
# WHO NEEDS THIS: Anyone who wants to train on cloud GPUs (SAM3 full fine-tuning,
# VesselFM, HPO sweeps, or when local GPU is too slow/small).
#
# WHO CAN SKIP: Anyone with a local GPU that fits their models (DynUNet fits 8 GB).
#
# Install: uv sync --extra sky && sky check
# Docs: https://docs.skypilot.co/en/latest/
SKYPILOT_DEFAULT_CLOUD=gcp
SKYPILOT_AUTOSTOP_MINUTES=30
# Hourly cost of the GPU instance in USD. Used by infrastructure_timing module
# to compute cost analysis (effective GPU rate, amortization, break-even).
# Set by launcher scripts based on provisioned instance type. 0.0 = local/free.
INSTANCE_HOURLY_USD=0.0

# ─── Lambda Labs (PRIMARY — VM-based, Docker works natively) ──────────────────
# Lambda Labs is the primary GPU provider for staging/prod because it provides
# actual VMs with Docker preinstalled. RunPod pods are containers (no Docker daemon).
# See: docs/runpod-vs-lambda-vs-rest-for-skypilot-with-docker.md
#
# WHO NEEDS THIS: Anyone using SkyPilot for Docker-based cloud GPU training.
# WHO CAN SKIP: Anyone training only locally.
#
# GPU pricing: A10 $0.86/hr (24 GB), A100 $1.48/hr (40 GB), H100 $2.86/hr (80 GB)
# Get your key: https://cloud.lambdalabs.com/api-keys
# Setup: echo "api_key = YOUR_KEY" > ~/.lambda_cloud/lambda_keys
LAMBDA_API_KEY=

# ─── RunPod (OPTIONAL — dev environment only, no Docker support) ──────────────
# RunPod pods ARE containers (not VMs). Docker-in-Docker is impossible.
# Use RunPod only for non-Docker dev workflows or interactive GPU access.
# For staging/prod (Docker-mandatory), use Lambda Labs instead.
#
# WHO NEEDS THIS: Developers wanting cheap GPU access without Docker overhead.
# WHO CAN SKIP: Anyone using staging/prod environments (use Lambda instead).
#
# Get your key: https://www.runpod.io/console/user/settings (API Keys section)
RUNPOD_API_KEY=

# ─── UpCloud VPS (RECOMMENDED — EUR 250 free trial) ──────────────────────
# UpCloud provides reliable VPS servers with a 30-day free trial (EUR 250).
# Finnish company with Helsinki datacenters. DEV-2xCPU-4GB (2 vCPU, 4 GB,
# 60 GB SSD) at EUR 19.42/month is comfortable for MLflow + PostgreSQL + MinIO.
#
# WHO NEEDS THIS: Anyone who wants a remote MLflow server for SkyPilot training
#                 or sharing experiments publicly.
# WHO CAN SKIP: Anyone training only locally, or using DagsHub for MLflow.
#
# Get your API token: https://hub.upcloud.com/account/api-tokens -> Create
UPCLOUD_TOKEN=
# Server zone: fi-hel1 (Helsinki FI), fi-hel2 (Helsinki FI), de-fra1 (Frankfurt DE),
#   nl-ams1 (Amsterdam NL), se-sto1 (Stockholm SE), us-chi1 (Chicago US),
#   us-nyc1 (New York US), us-sjo1 (San Jose US), sg-sin1 (Singapore),
#   au-syd1 (Sydney AU)
UPCLOUD_ZONE=fi-hel1
# Server plan: DEV-1xCPU-2GB (EUR 8.70), DEV-2xCPU-4GB (EUR 19.42)
UPCLOUD_PLAN=DEV-2xCPU-4GB

# ─── DVC Cloud Storage (UpCloud S3 — data transport for RunPod) ────────────
# DVC remote for pulling MiniVess training data to cloud GPU instances.
# The UpCloud Object Storage bucket is provisioned by Pulumi (deployment/pulumi/).
# Endpoint URL comes from: pulumi stack output s3_endpoint
#
# WHO NEEDS THIS: Anyone running GPU smoke tests on RunPod via SkyPilot.
# WHO CAN SKIP: Anyone training only locally with volume-mounted data.
DVC_S3_ENDPOINT_URL=
DVC_S3_ACCESS_KEY=
DVC_S3_SECRET_KEY=
DVC_S3_BUCKET=minivess-dvc-data
# DVC remote name: "minio" for local Docker, "upcloud" for cloud
DVC_REMOTE=upcloud

# ─── Hetzner VPS (ARCHIVED — long-term fallback at EUR 3.79/mo) ─────────
# Hetzner Cloud provides reliable VPS servers. CX22 (2 vCPU, 4 GB, 40 GB) at
# EUR 3.79/month. Use after UpCloud trial ends, or if you prefer lower cost.
# See: docs/planning/hetzner-mlflow-plan.md (status: archived-fallback)
#
# Get your API token: https://console.hetzner.cloud/ -> project -> Security -> API tokens
HETZNER_API_TOKEN=
# Server location: fsn1 (Falkenstein DE), nbg1 (Nuremberg DE), hel1 (Helsinki FI),
#                  ash (Ashburn US), hil (Hillsboro US)
HETZNER_LOCATION=fsn1
# Server type: cx22 (2 vCPU/4GB, EUR 3.79), cx32 (4 vCPU/8GB, EUR 6.80)
HETZNER_SERVER_TYPE=cx22

# ─── Oracle Cloud Infrastructure (DEPRECATED — rejected 2026-03-13) ──────
# Oracle Cloud Always Free was rejected due to chronic ARM capacity shortage
# in Frankfurt (all 3 ADs exhausted), no region change possible, and poor DevEx.
# Kept for reference only. Use UpCloud (trial) or Hetzner (long-term) instead.
# See: docs/planning/oracle-config-planning.md (status: rejected)
OCI_TENANCY_OCID=
OCI_USER_OCID=
OCI_COMPARTMENT_OCID=
OCI_REGION=eu-frankfurt-1
OCI_FINGERPRINT=
OCI_PRIVATE_KEY_PATH=~/.oci/oci_api_key.pem

# ─── Docker Registry (for SkyPilot cloud GPU training) ─────────────────────
# SkyPilot pulls the minivess-base Docker image from a registry on cloud GPUs.
# Without this, SkyPilot cannot pull the Docker image on RunPod/Lambda/AWS.
#
# WHO NEEDS THIS: Anyone pushing Docker images for cloud GPU training.
# WHO CAN SKIP: Anyone training only locally.
#
# The registry is CONFIGURABLE — use whichever registry you prefer:
#   GHCR:       DOCKER_REGISTRY=ghcr.io/petteriteikari
#   Docker Hub: DOCKER_REGISTRY=docker.io/petteriteikari
#   AWS ECR:    DOCKER_REGISTRY=123456789.dkr.ecr.us-east-1.amazonaws.com
#   GCP GAR:    DOCKER_REGISTRY=us-docker.pkg.dev/project-id/repo
#   Azure ACR:  DOCKER_REGISTRY=myregistry.azurecr.io
#
# Login examples:
#   GHCR:       echo $GITHUB_TOKEN | docker login ghcr.io -u $GHCR_USERNAME --password-stdin
#   Docker Hub: docker login -u $DOCKER_USERNAME
#   AWS ECR:    aws ecr get-login-password | docker login --username AWS --password-stdin $DOCKER_REGISTRY
#
# Push: docker tag minivess-base:latest $DOCKER_REGISTRY/minivess-base:latest
#       docker push $DOCKER_REGISTRY/minivess-base:latest
DOCKER_REGISTRY=petteriteikari
DOCKER_IMAGE_NAME=minivess-base
DOCKER_IMAGE_TAG=latest

# Docker Hub credentials (for push only — pulls are public, no auth needed)
# Create access token: https://hub.docker.com/settings/security
# RunPod uses Docker Hub (public). GCP uses GAR (ADC auth). GHCR is CI-only.
DOCKERHUB_TOKEN=

# GitHub credentials (for GHCR push in CI, gh CLI, etc.)
# Create a classic PAT with `write:packages` + `read:packages` scope:
#   https://github.com/settings/tokens/new?scopes=write:packages,read:packages
GITHUB_TOKEN=
GHCR_USERNAME=petteriteikari

# ─── Cloudflare DNS (OPTIONAL — custom domain for MLflow) ────────────────────
# If you want your remote MLflow server at a custom domain like
# mlflow.minivess.fi instead of a raw IP address, you need Cloudflare DNS.
# Pulumi uses these to create the DNS A record automatically.
#
# WHO NEEDS THIS: Anyone deploying MLflow to Oracle Cloud with a custom domain.
# WHO CAN SKIP: Everyone else. You can access MLflow by IP without a domain.
#
# Get your token: Cloudflare Dashboard -> My Profile -> API Tokens -> Create Token
#   Permission needed: Zone:DNS:Edit (scoped to your domain)
# Get your zone ID: Cloudflare Dashboard -> your domain -> Overview sidebar
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ─── Pulumi IaC (OPTIONAL — infrastructure-as-code for cloud deployment) ─────
# Pulumi automates provisioning the UpCloud/Hetzner VPS, Docker setup, TLS
# certificates, and DNS records via a single `pulumi up` command.
#
# WHO NEEDS THIS: Anyone deploying MLflow to UpCloud/Hetzner (or any cloud) via IaC.
# WHO CAN SKIP: Anyone using the setup scripts (upcloud-setup-script.sh or
#               hetzner-setup-script.sh), or not deploying to cloud at all.
#
# Free tier: 1 user, unlimited resources, unlimited deployments.
# Sign up: https://app.pulumi.com/signup
PULUMI_ACCESS_TOKEN=
# Passphrase for Pulumi stack secrets encryption (set during `pulumi stack init`).
# Required for `pulumi up`, `pulumi stack output`, etc.
PULUMI_CONFIG_PASSPHRASE=

# ─── Cloud MLflow Auth (REMOVED — UpCloud legacy) ───────────────────────────
# MLFLOW_CLOUD_* variables were removed in the single-MLFLOW_TRACKING_URI
# simplification. Use MLFLOW_TRACKING_URI (above) for the server URL, and
# MLFLOW_TRACKING_USERNAME / MLFLOW_TRACKING_PASSWORD (above) for auth.
# Cloud tests in tests/v2/cloud/ now skip when MLFLOW_TRACKING_URI is localhost.

# ─── MLflow Server Version (PINNED — single source of truth) ─────────────────
# The MLflow server version MUST match the client version in the Docker training
# image. A v2.20 server vs v3.10 client caused 8+ hours of artifact upload
# debugging (see .claude/metalearning/2026-03-14-mlflow-version-mismatch-fuckup.md).
# Both UpCloud and GCP Pulumi stacks reference this variable.
#
# Check client version: uv run python -c "import mlflow; print(mlflow.__version__)"
MLFLOW_SERVER_VERSION=3.10.0

# ─── GCP (PRIMARY — full stack for staging + prod) ───────────────────────────
# GCP provides same-region everything: GPU compute + MLflow + storage + Docker
# registry. SkyPilot spot instances (60-91% cheaper) with auto-recovery.
# See: docs/planning/gcp-spot-with-skypilot-and-pulumi-up-plan.xml
#
# WHO NEEDS THIS: Anyone using GCP for training (staging/prod environments).
# WHO CAN SKIP: Anyone training only locally or using Lambda/RunPod.
#
# Setup: See docs/planning/gcp-setup-tutorial.md
#   1. gcloud init → select project
#   2. gcloud auth application-default login
#   3. Enable APIs: compute, storage, iam, run, sqladmin, artifactregistry
#   4. Request GPU quota: GPUS_ALL_REGIONS >= 1
#   5. sky check gcp → enabled
GCP_PROJECT=minivess-mlops
GCP_REGION=europe-west4

# GCS Buckets (created by Pulumi in deployment/pulumi/gcp/)
GCS_MLFLOW_BUCKET=minivess-mlflow-artifacts
GCS_DVC_BUCKET=minivess-dvc-data
GCS_CHECKPOINT_BUCKET=minivess-mlops-checkpoints

# GCP MLflow on Cloud Run: set MLFLOW_TRACKING_URI to Cloud Run URL.
# Populated by `pulumi stack output mlflow_url` from GCP stack.
# Auth via MLFLOW_TRACKING_USERNAME / MLFLOW_TRACKING_PASSWORD (in MLflow section above).

# ─── External Test Data ────────────────────────────────────────────────────────
# Directory containing external test datasets (DeepVess) for generalization eval.
# Docker containers mount this as /app/data/external (read-only).
# Download DeepVess from Cornell eCommons, place in data/external/deepvess/
# TubeNet EXCLUDED (olfactory bulb, different organ). VesselNN = drift detection only.
EXTERNAL_DATA_DIR=data/external
