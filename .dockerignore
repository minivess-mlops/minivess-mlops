# MinIVess MLOps — Docker build context exclusions
#
# SECURITY: .env must be excluded to prevent credential leaks into image layers.
# PERFORMANCE: Exclude large data dirs and caches to reduce build context size.

# ── Secrets and credentials ──────────────────────────────────────────────────
.env
*.env
secrets/

# ── Git and VCS ───────────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ── Python artifacts ──────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/
.eggs/

# ── Test and lint caches ──────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# ── ML artifacts (large, belong in registries not images) ────────────────────
mlruns/
outputs/duckdb/
outputs/checkpoints/
*.onnx

# ── Raw data (fetched at runtime via DVC / download scripts) ─────────────────
data/minivess/
data/raw/
# Exception: .dvc tracking files are tiny text files needed for `dvc pull` on cloud VMs
!data/raw/*.dvc

# ── Node and frontend ─────────────────────────────────────────────────────────
node_modules/

# ── Editor and IDE ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.tmp

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
outputs/logs/

# ── Documentation and wiki (not needed in runtime image) ─────────────────────
docs/
wiki/
*.md
# Exception: README.md is needed by pyproject.toml (uv sync fails without it)
!README.md

# ── CI/CD ────────────────────────────────────────────────────────────────────
.github/

# ── Tests (not needed in production image) ───────────────────────────────────
tests/

# ── Claude Code internal ──────────────────────────────────────────────────────
.claude/
state/
